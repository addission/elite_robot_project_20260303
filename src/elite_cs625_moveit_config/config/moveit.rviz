Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Grid1/Line Style1
        - /MotionPlanning1/Scene Geometry1
        - /MotionPlanning1/Scene Robot1
        - /TF1
        - /TF1/Frames1
        - /TF1/Frames1/my_end_effector_link1
        - /TF1/Frames1/tcp_pose1
      Splitter Ratio: 0.5
    Tree Height: 590
  - Class: rviz_common/Help
    Name: Help
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
